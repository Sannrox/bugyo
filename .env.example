# Bugyo environment variables
#
# Copy this file to `.env` and adjust as needed. `.env` is gitignored and must
# never be committed. All variables are optional; sensible defaults are used
# when unset.

# Directory where Bugyo stores its own config/state.
# Default: platform config dir (e.g. ~/.config/bugyo).
# BUGYO_CONFIG_HOME=

# Root of the kiro-orchestrator state layout Bugyo interoperates with.
# Default: the orchestrator's own default location.
# KIRO_ORCH_HOME=

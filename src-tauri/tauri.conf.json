{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bugyo",
  "version": "0.1.0",
  "identifier": "dev.bugyo.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bugyo",
        "width": 800,
        "height": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 The Bugyo Authors",
    "publisher": "The Bugyo Authors",
    "shortDescription": "Command center for kiro-cli sessions",
    "longDescription": "Bugyo orchestrates many kiro-cli agent sessions in parallel over ACP — each isolated in its own git worktree — with a diff-review-and-merge flow and a human-in-the-loop approval model.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Sannrox/bugyo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2NDJFNkRDRDA5RTY3QTMKUldTalo1N1EzT1pDWm1jOTNGdHVyR3pLck9tb1pzQ3JWc0QyZkYyU05uWjF1OHZ2SUxBNysyTk4K"
    }
  }
}
